# ─────────────────────────────────────────────────────────────────────────────
# API Environment Variables — copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. For local Docker: lms_user / lms_password / lms_db
DATABASE_URL="postgresql://lms_user:lms_password@localhost:5432/lms_db"

# ─── Redis ────────────────────────────────────────────────────────────────────
# Optional — used for caching and queue workers (can be left as default for dev)
REDIS_URL="redis://localhost:6379"

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Change JWT_SECRET to a long, random string in production
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# URL of the Next.js frontend (used for CORS and email links)
APP_URL=http://localhost:3003

# ─── AWS S3 (file uploads) ────────────────────────────────────────────────────
# For learner photo uploads and document storage. Leave blank for local dev.
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-s3-bucket-name

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Leave all blank to use mock mode — emails are logged to console, not sent.
# SendGrid:  SMTP_HOST=smtp.sendgrid.net   SMTP_USER=apikey   SMTP_PASS=<SG_API_KEY>
# Gmail:     SMTP_HOST=smtp.gmail.com      SMTP_USER=<email>  SMTP_PASS=<app_password>
# Brevo:     SMTP_HOST=smtp-relay.brevo.com  SMTP_PORT=587  SMTP_USER=<email>  SMTP_PASS=<key>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="UL-Junior Project <noreply@ul-junior.co.za>"
